# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/enrgyastro

# Session / Auth
SESSION_SECRET=change_this_to_a_long_random_string
JWT_SECRET=change_this_to_a_long_random_string

# Admin (single practitioner account, auto-seeded on first boot)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@enrgyastro.com
ADMIN_PASSWORD=change_me_on_first_login

# Prokerala API (Panchang / Kundli / Matching / Dosha)
# Get credentials at https://api.prokerala.com/
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=
PROKERALA_TOKEN_URL=https://api.prokerala.com/token
PROKERALA_BASE_URL=https://api.prokerala.com/v2/astrology

# SMTP (use Hostinger's built-in SMTP, same pattern as ICAS LMS)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EnrgyAstro <noreply@enrgyastro.com>"

# WhatsApp contact (pre-filled message link, same pattern as ICAS)
WHATSAPP_NUMBER=91XXXXXXXXXX

# Razorpay (for paid consultation booking — Phase 2)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
