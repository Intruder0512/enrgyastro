<section class="page-header"><div class="container"><h1>Numerology Calculator</h1></div></section>
<section class="container">
  <form method="POST" action="/dashboard/numerology" class="booking-form">
    <label>Date of Birth<input type="date" name="dob" required></label>
    <label>First Name<input type="text" name="firstName" required></label>
    <label>Middle Name (optional)<input type="text" name="middleName"></label>
    <label>Last Name<input type="text" name="lastName" required></label>
    <button type="submit" class="btn btn-primary btn-full">Calculate</button>
  </form>
</section>
