<section class="page-header"><div class="container"><h1>Your Numerology Report</h1></div></section>
<section class="container prose-page">
  <% if (error) { %>
    <p class="widget-error"><%= error %></p>
  <% } else { %>
    <div class="result-hero">
      <div class="result-stat"><span><%= lifePath?.number ?? '—' %></span><p>Life Path Number</p></div>
      <div class="result-stat"><span><%= destiny?.number ?? '—' %></span><p>Destiny Number</p></div>
    </div>
    <% if (lifePath?.description) { %>
      <div class="result-section">
        <h3><%= lifePath.name || 'Life Path Number' %></h3>
        <p><%= lifePath.description %></p>
      </div>
    <% } %>
    <% if (destiny?.description) { %>
      <div class="result-section">
        <h3><%= destiny.name || 'Destiny Number' %></h3>
        <p><%= destiny.description %></p>
      </div>
    <% } %>
  <% } %>
</section>
