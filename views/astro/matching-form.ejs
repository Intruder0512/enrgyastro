<section class="page-header"><div class="container"><h1>Kundli Matching (Guna Milan)</h1></div></section>
<section class="container">
  <form method="POST" action="/dashboard/matching" class="booking-form">
    <fieldset>
      <legend>Groom's Details</legend>
      <label>Date of Birth<input type="date" name="boyDob" required></label>
      <label>Time of Birth<input type="time" name="boyTob" required></label>
      <label>Latitude<input type="number" step="any" name="boyLat" required></label>
      <label>Longitude<input type="number" step="any" name="boyLng" required></label>
    </fieldset>
    <fieldset>
      <legend>Bride's Details</legend>
      <label>Date of Birth<input type="date" name="girlDob" required></label>
      <label>Time of Birth<input type="time" name="girlTob" required></label>
      <label>Latitude<input type="number" step="any" name="girlLat" required></label>
      <label>Longitude<input type="number" step="any" name="girlLng" required></label>
    </fieldset>
    <button type="submit" class="btn btn-primary btn-full">Check Compatibility</button>
  </form>
</section>
