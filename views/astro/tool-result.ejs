<section class="page-header"><div class="container"><h1><%= tool.label %></h1></div></section>
<section class="container prose-page">
  <% if (error) { %>
    <p class="widget-error"><%= error %></p>
  <% } else if (tool.isSvg) { %>
    <div class="chart-svg-wrap"><%- result.svg %></div>
  <% } else { %>
    <div id="pretty-root"></div>
    <script type="application/json" id="result-data"><%- JSON.stringify(result.data).replace(/</g, '\u003c') %></script>
    <script>
      renderPrettyJson(document.getElementById('pretty-root'), JSON.parse(document.getElementById('result-data').textContent));
    </script>
  <% } %>
</section>
