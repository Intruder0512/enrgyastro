<section class="page-header"><div class="container"><h1>Birth Chart</h1></div></section>
<section class="container">
  <form method="POST" action="/dashboard/chart" class="booking-form">
    <label>Date of Birth<input type="date" name="dob" required></label>
    <label>Time of Birth<input type="time" name="tob" required></label>
    <label>Latitude<input type="number" step="any" name="lat" required></label>
    <label>Longitude<input type="number" step="any" name="lng" required></label>
    <label>Chart Type
      <select name="chartType">
        <option value="rasi">Rasi (Main Birth Chart)</option>
        <option value="navamsa">Navamsa</option>
        <option value="lagna">Lagna</option>
        <option value="dasamsa">Dasamsa</option>
      </select>
    </label>
    <label>Chart Style
      <select name="chartStyle">
        <option value="south-indian">South Indian</option>
        <option value="north-indian">North Indian</option>
      </select>
    </label>
    <button type="submit" class="btn btn-primary btn-full">Generate Chart</button>
  </form>
</section>
