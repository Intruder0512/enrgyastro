<section class="page-header"><div class="container"><h1><%= viewedUser.name %>'s Bookings</h1><p><%= viewedUser.email %> &middot; <%= viewedUser.phone %></p></div></section>
<section class="container">
  <%- include('../partials/appointments-calendar', { appointments: appointments }) %>

  <% if (!appointments.length) { %>
    <p>This user has no appointments yet.</p>
  <% } else { %>
    <table class="data-table">
      <thead><tr><th>Service</th><th>Date</th><th>Slot</th><th>Mode</th><th>Status</th></tr></thead>
      <tbody>
        <% appointments.forEach(function(a) { %>
          <tr>
            <td><%= a.service.name %></td>
            <td><%= a.date.toDateString() %></td>
            <td><%= a.slot %></td>
            <td><%= a.mode %></td>
            <td><span class="status status-<%= a.status %>"><%= a.status %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <a href="/admin/users" class="btn btn-outline">Back to All Users</a>
</section>
