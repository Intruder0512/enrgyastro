<section class="page-header"><div class="container"><h1>Manage Blog</h1></div></section>
<section class="container">
  <a href="/admin/blog/new" class="btn btn-primary" style="margin-bottom:16px;display:inline-block;">+ New Post</a>

  <% if (!posts.length) { %>
    <p>No blog posts yet.</p>
  <% } else { %>
    <table class="data-table">
      <thead><tr><th>Title</th><th>Status</th><th>Media</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% posts.forEach(function(p) { %>
          <tr>
            <td><%= p.title %></td>
            <td><span class="status status-<%= p.status === 'published' ? 'confirmed' : 'pending' %>"><%= p.status %></span></td>
            <td><%= [p.coverImage ? 'Image' : null, (p.videoUrl || p.videoFile) ? 'Video' : null].filter(Boolean).join(' + ') || '—' %></td>
            <td><%= p.publishedAt ? new Date(p.publishedAt).toDateString() : new Date(p.createdAt).toDateString() %></td>
            <td style="display:flex;gap:6px;">
              <a href="/admin/blog/<%= p._id %>/edit" class="btn btn-small btn-outline">Edit</a>
              <form method="POST" action="/admin/blog/<%= p._id %>/toggle" class="inline-form">
                <button type="submit" class="btn btn-small btn-outline"><%= p.status === 'published' ? 'Unpublish' : 'Publish' %></button>
              </form>
              <form method="POST" action="/admin/blog/<%= p._id %>/delete" class="inline-form" onsubmit="return confirm('Delete this post permanently?');">
                <button type="submit" class="btn btn-small btn-outline">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>
