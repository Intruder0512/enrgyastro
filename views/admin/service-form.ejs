<section class="page-header"><div class="container"><h1><%= service ? 'Edit Service' : 'Add New Service' %></h1></div></section>
<section class="container">
  <% if (errors && errors.length) { %>
    <ul class="form-errors"><% errors.forEach(function(e) { %><li><%= e.msg %></li><% }) %></ul>
  <% } %>
  <form method="POST" action="<%= service && service._id ? '/admin/services/' + service._id : '/admin/services' %>" class="booking-form">
    <label>Service Name<input type="text" name="name" value="<%= service?.name || '' %>" required></label>

    <label>Category
      <select name="category" required>
        <% ['kundli','matching','palmistry','vastu','horoscope','career','general'].forEach(function(c) { %>
          <option value="<%= c %>" <%= service?.category === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </label>

    <label>Short Description (shown on cards)
      <input type="text" name="shortDescription" value="<%= service?.shortDescription || '' %>" maxlength="120">
    </label>

    <label>Full Description
      <textarea name="description" rows="4" required><%= service?.description || '' %></textarea>
    </label>

    <label>Price (₹, 0 for free)
      <input type="number" name="price" min="0" value="<%= service?.price ?? 0 %>" required>
    </label>

    <label>Duration (minutes)
      <input type="number" name="durationMinutes" min="10" step="5" value="<%= service?.durationMinutes ?? 30 %>" required>
    </label>

    <fieldset>
      <legend>Consultation Mode</legend>
      <label style="display:inline-flex;align-items:center;gap:6px;width:auto;">
        <input type="checkbox" name="mode" value="online" style="width:auto;" <%= (!service || service.mode?.includes('online')) ? 'checked' : '' %>>
        Online
      </label>
      &nbsp;&nbsp;
      <label style="display:inline-flex;align-items:center;gap:6px;width:auto;">
        <input type="checkbox" name="mode" value="offline" style="width:auto;" <%= (!service || service.mode?.includes('offline')) ? 'checked' : '' %>>
        Offline (In-person)
      </label>
    </fieldset>

    <button type="submit" class="btn btn-primary btn-full"><%= service && service._id ? 'Save Changes' : 'Create Service' %></button>
  </form>
</section>
